## Data Fetching

### TanStack Query Hooks
```typescript
// src/features/[feature]/api/use-[resource].ts
import { useQuery } from '@tanstack/react-query';
import { get[Resource]s } from './[resource]-api';

export function use[Resource]s() {
  return useQuery({
    queryKey: ['[resource]s'],
    queryFn: get[Resource]s,
  });
}
```

### API Functions
```typescript
// src/features/[feature]/api/[resource]-api.ts
import { supabase } from '@/lib/supabase';
import type { [Resource] } from '../types';

export async function get[Resource]s(): Promise<[Resource][]> {
  const { data, error } = await supabase
    .from('[table]')
    .select('*');

  if (error) throw error;
  return data || [];
}
```

---

## State Management

### Zustand Store Pattern
```typescript
// src/features/[feature]/stores/[feature]-store.ts
import { create } from 'zustand';

type [Feature]State = {
  // state
  selectedId: string | null;
  // actions
  setSelectedId: (id: string | null) => void;
};

export const use[Feature]Store = create<[Feature]State>((set) => ({
  selectedId: null,
  setSelectedId: (id) => set({ selectedId: id }),
}));
```

